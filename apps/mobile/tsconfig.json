{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@chakula/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@chakula/shared-schemas": ["../../packages/shared-schemas/src/index.ts"],
      "@chakula/shared-utils": ["../../packages/shared-utils/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}