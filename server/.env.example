# Copy this file to .env and fill in your values
# cp .env.example .env

NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:8081
RESTAURANT_DASHBOARD_URL=http://localhost:3001
ADMIN_PANEL_URL=http://localhost:3002

DATABASE_URL=postgresql://user:password@localhost:5432/chakula_dev

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another-secret-key-different-from-jwt-secret
REFRESH_TOKEN_EXPIRES_IN=30d

OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=CHAKULA

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_MAPS_API_KEY=your-maps-api-key

MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.com/v1/webhooks/mpesa/callback
MPESA_ENVIRONMENT=sandbox

FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxx
FLUTTERWAVE_ENCRYPTION_KEY=xxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret

RESEND_API_KEY=re_xxx
EMAIL_FROM=no-reply@chakula.com
EMAIL_FROM_NAME=Chakula

SENTRY_DSN=https://xxx@o0.ingest.sentry.io/xxx

DEFAULT_COMMISSION_PERCENTAGE=18
SERVICE_FEE_FIXED=50
BASE_DELIVERY_FEE=80
DELIVERY_FEE_PER_KM=20
ORDER_TIMEOUT_MINUTES=2
MAX_DELIVERY_RADIUS_KM=15
CURRENCY=KES
COUNTRY_CODE=KE
RIDER_BASE_EARNING=80
RIDER_EARNING_PER_KM=25